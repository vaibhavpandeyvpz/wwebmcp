{
  "name": "wappmcp",
  "version": "0.3.7",
  "description": "TypeScript stdio MCP server and CLI for WhatsApp Web.",
  "type": "module",
  "bin": {
    "wappmcp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-instructions.mjs",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "whatsapp",
    "whatsapp-web",
    "cli",
    "typescript"
  ],
  "author": "Vaibhav Pandey <contact@vaibhavpandey.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaibhavpandeyvpz/wappmcp.git"
  },
  "bugs": {
    "url": "https://github.com/vaibhavpandeyvpz/wappmcp/issues"
  },
  "homepage": "https://github.com/vaibhavpandeyvpz/wappmcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cli-spinners": "^3.4.0",
    "commander": "^14.0.3",
    "ink": "^7.0.1",
    "ink-select-input": "^6.2.0",
    "react": "^19.2.5",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.14",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
